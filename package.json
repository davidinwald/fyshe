{
  "name": "fyshe",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx,css}\"",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:studio": "pnpm --filter @fyshe/db db:studio",
    "db:seed": "pnpm --filter @fyshe/db db:seed",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "simple-git-hooks": "^2.11.0",
    "turbo": "^2.4.0"
  },
  "simple-git-hooks": {
    "prepare-commit-msg": "node tooling/scripts/prepare-commit-msg.mjs $1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
