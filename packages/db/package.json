{
  "name": "@fyshe/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-flies": "tsx ../../tooling/scripts/seed-fly-data.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0"
  },
  "devDependencies": {
    "@fyshe/config": "workspace:*",
    "@types/node": "^22.0.0",
    "prisma": "^6.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "prisma": {
    "schema": "prisma/schema"
  }
}
